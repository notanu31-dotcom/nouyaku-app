// ===== 初期データ生成 =====
let _nextId = 100;
const nid = () => ++_nextId;

function buildEntry(cropKey, varietyId, sowDateOverride) {
const varieties = VARIETY_PRESETS[cropKey] || [];
const variety = varieties.find(v=>v.id===varietyId) || varieties[0];
if (!variety) return null;
const sowDate = sowDateOverride || makeDate(variety.sowMonth, variety.sowDay);
return {
id: nid(),
cropKey,
varietyId: variety.id,
varietyName: variety.name,
sowDate,
harvestOffset: variety.harvestOffset,
taskOverrides: {}, // taskName → offsetDays（実績値上書き）
tasks: variety.tasks.map(t => ({…t, id: nid()})),
};
}

